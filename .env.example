# --- GEMINI AI (Servidor/Chatbot) ---
# Obtén tu clave en https://aistudio.google.com/
GEMINI_API_KEY="tu_clave_aquí"

# --- MAPBOX (Frontend/Mapas) ---
# Usado para renderizar el mapa de sedes. Obtén el token en https://www.mapbox.com/
PUBLIC_MAPBOX_TOKEN="pk.tu_token_aquí"

# --- SUPABASE (Auth & Favoritos) ---
# Claves públicas para la inicialización del cliente de Supabase (integrado en el frontend).
# Copia estos valores de la configuración de Supabase (Settings -> API).
PUBLIC_SUPABASE_URL="https://tu_proyecto.supabase.co"
PUBLIC_SUPABASE_ANON_KEY="tu_clave_anon_aquí"

# --- GITHUB (Opcional - Automatización) ---
# Solo necesario para que los GitHub Actions hagan push de los datos.
# No se usa en desarrollo local.
# GH_PAT="tu_pat_aqui"
